<Window x:Class="MarketBasketAnalysis.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Анализ покупательских корзин — Вход" 
        Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Window.Resources>
        <DropShadowEffect x:Key="ModernShadow" 
                          Color="#0F172A" 
                          BlurRadius="30" 
                          Direction="270" 
                          Opacity="0.06" 
                          ShadowDepth="5"/>
    </Window.Resources>

    <Grid>
        <Border Width="420" 
                Height="480" 
                Background="#FFFFFF" 
                CornerRadius="12" 
                Effect="{StaticResource ModernShadow}"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">

            <StackPanel VerticalAlignment="Center" Margin="45,0,45,0">

                <iconPacks:PackIconMaterial Kind="Shopping" 
                                            Width="45" Height="45" 
                                            Foreground="#3498DB" 
                                            HorizontalAlignment="Center" 
                                            Margin="0,0,0,15"/>

                <TextBlock Text="Авторизация" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#1E293B" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Введите свои данные для доступа к системе" 
                           FontSize="13" 
                           Foreground="#64748B" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Логин или Email" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#475569" 
                           Margin="0,0,0,8"/>

                <Border BorderBrush="#CBD5E1" 
                        BorderThickness="1" 
                        CornerRadius="6" 
                        Background="#F8FAFC"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="Account" 
                                                    Width="18" Height="18" 
                                                    Foreground="#94A3B8" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        <TextBox x:Name="TxtLogin" 
                                 Grid.Column="1"
                                 Height="38" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 VerticalContentAlignment="Center" 
                                 Padding="5,0,10,0"
                                 FontSize="14"
                                 Foreground="#1E293B"
                                 FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"/>
                    </Grid>
                </Border>

                <TextBlock Text="Пароль" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#475569" 
                           Margin="0,0,0,8"/>

                <Border BorderBrush="#CBD5E1" 
                        BorderThickness="1" 
                        CornerRadius="6" 
                        Background="#F8FAFC"
                        Margin="0,0,0,35">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="Lock" 
                                                    Width="18" Height="18" 
                                                    Foreground="#94A3B8" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        <PasswordBox x:Name="TxtPassword" 
                                     Grid.Column="1"
                                     Height="38" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     VerticalContentAlignment="Center" 
                                     Padding="5,0,10,0"
                                     FontSize="14"
                                     Foreground="#1E293B"/>
                    </Grid>
                </Border>

                <Button x:Name="BtnLogin" 
                        Content="Войти в систему" 
                        Click="BtnLogin_Click"
                        IsDefault="True"
                        Height="42" 
                        Background="#3498DB" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        FontSize="15"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2980B9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>